<?xml version="1.0"?>

<robot name="arm_gz" xmlns:xacro="http://ros.org/wiki/xacro">

        <!--
        RoboNav Arm URDF - 5 degrees of freedom
        joint 1 is prismatic along y axis (left-right motion)
        joint 2,3,4 are revolute along y axis (pitch motion)
        joint 5 is attached to joint 4 and is along x-axis (roll motion)
        aka joint 4 and 5 form a wrist (pitch and roll)

        Gazebo version: uses gz_ros2_control instead of MuJoCo simulator.
        -->

        <xacro:include filename="$(find cartesian_controller_simulation)/urdf/joint_gz.urdf.xacro"/>

        <!-- ROS2 control interfaces -->
        <ros2_control name="cartesian_controller_simulation" type="system">

                <joint name="joint1"> <!-- base slide - prismatic -->
                        <command_interface name="position">
                                <param name="min">-0.5</param>
                                <param name="max">0.5</param>
                        </command_interface>
                        <command_interface name="velocity">
                                <param name="min">-1</param>
                                <param name="max">1</param>
                        </command_interface>
                        <state_interface name="position"/>
                        <state_interface name="velocity"/>
                        <state_interface name="effort"/>
                </joint>

                <xacro:joint_interface name="joint2" /> <!-- shoulder pitch -->
                <xacro:joint_interface name="joint3" /> <!-- elbow pitch -->
                <xacro:joint_interface name="joint4" /> <!-- wrist pitch -->
                <xacro:joint_interface name="joint5" /> <!-- wrist roll -->

                <hardware>
                        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
                </hardware>

        </ros2_control>

        <!-- Gazebo plugin to load controller manager -->
        <gazebo>
                <plugin filename="gz_ros2_control-system"
                        name="gz_ros2_control::GazeboSimROS2ControlPlugin">
                        <parameters>$(find cartesian_controller_simulation)/config/controller_manager_arm.yaml</parameters>
                </plugin>
        </gazebo>

        <!-- joint properties -->
        <xacro:property name="joint_radius" value="0.02" />
        <xacro:property name="joint_length" value="0.03" />

        <!-- link properties -->
        <xacro:property name="link_radius" value="0.01" />
        <xacro:property name="link1_length" value="0.1" />
        <xacro:property name="link2_length" value="0.2" />
        <xacro:property name="link3_length" value="0.15" />
        <xacro:property name="link4_length" value="0.1" />
        <xacro:property name="link5_length" value="0.1" />

        <!-- colors -->
        <material name="joint_part1">
                <color rgba="0.525 0.713 0.662 1.0"/>
        </material>
        <material name="joint_part2">
                <color rgba="0.462 0.196 0.411 1.0"/>
        </material>
        <material name="base">
                <color rgba="0.956863 0.796078 0.631373 1.0"/>
        </material>
        <material name="tip">
                <color rgba="0.956 0.450 0.243 1.0"/>
        </material>
        <material name="link1">
                <color rgba="0.949 0.631 0.823 1.0"/>
        </material>
        <material name="link2">
                <color rgba="0.133 0.827 0.435 1.0"/>
        </material>
        <material name="link3">
                <color rgba="0.968 0.721 0.313 1.0"/>
        </material>
        <material name="link4">
                <color rgba="0.52549 0.529412 0.647059 1.0"/>
        </material>
        <material name="link5">
                <color rgba="0.478431 0.415686 0.662745 1.0"/>
        </material>

        <!-- Connect to world -->
        <!-- <link name="world" />
                <joint name="world_joint" type="fixed">
                        <parent link="world" />
                        <child link="base_link" />
                        <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
                </joint> -->

        <link name="base_link">
                <inertial>
                        <origin xyz="0 0 ${joint_length / 2.0}" rpy="0 0 0"/>
                        <mass value="1"/>
                        <inertia ixx="1.0" ixy="0" ixz="0" iyy="1.0" iyz="0" izz="1.0" />
                </inertial>
                <visual name="base">
                        <origin xyz="0 0 0" rpy="0 0 0" />
                        <geometry>
                                <cylinder length="${joint_length}" radius="${joint_radius}"/>
                        </geometry>
                        <material name="base"/>
                </visual>
        </link>

        <!-- Prismatic slider -->
        <joint name="joint1" type="prismatic">
                <parent link="base_link" />
                <child link="link1" />
                <origin xyz="0.0 0.0 ${3.0 / 2.0 * joint_length}" rpy="0.0 0.0 0.0" />
                <axis xyz="0 1 0" />
                <limit lower="-0.5" upper="0.5" effort="100" velocity="1.0"/>
        </joint>

        <link name="link1">
                <inertial>
                        <origin xyz="0 0 ${link1_length / 2.0}" rpy="0 0 0"/>
                        <mass value="1"/>
                        <inertia ixx="1.0" ixy="0" ixz="0" iyy="1.0" iyz="0" izz="1.0" />
                </inertial>
                <visual name="joint1_bottom">
                        <origin xyz="0 0 0" rpy="0 0 0" />
                        <geometry>
                                <cylinder length="${joint_length}" radius="${joint_radius}"/>
                        </geometry>
                        <material name="link1"/>
                </visual>
                <visual name="link">
                        <origin xyz="0 0 ${link1_length / 2.0}" rpy="0 0 0" />
                        <geometry>
                                <cylinder length="${link1_length}" radius="${link_radius}"/>
                        </geometry>
                        <material name="link1"/>
                </visual>
                <visual name="joint2_top">
                        <origin xyz="0 0 ${link1_length}" rpy="1.5708 0 0" />
                        <geometry>
                                <cylinder length="${joint_length}" radius="${joint_radius}"/>
                        </geometry>
                        <material name="link1"/>
                </visual>
        </link>

        <!-- Shoulder pitch joint -->
        <joint name="joint2" type="revolute">
                <parent link="link1" />
                <child link="link2" />
                <origin xyz="0.0 ${joint_length} ${link1_length}" rpy="0.0 ${pi / 2.0} 0.0" />
                <axis xyz="0 1 0" />
                <limit lower="${-2.0 * pi}" upper="${2.0 * pi}" effort="1.0" velocity="10.0"/>
        </joint>

        <link name="link2">
                <inertial>
                        <origin xyz="0 0 ${link2_length / 2.0}" rpy="0 0 0"/>
                        <mass value="1"/>
                        <inertia ixx="1.0" ixy="0" ixz="0" iyy="1.0" iyz="0" izz="1.0" />
                </inertial>
                <visual name="joint2">
                        <origin xyz="0 0 0" rpy="1.5708 0 0" />
                        <geometry>
                                <cylinder length="${joint_length}" radius="${joint_radius}"/>
                        </geometry>
                        <material name="link2"/>
                </visual>
                <visual name="link">
                        <origin xyz="0 0 ${link2_length / 2.0}" rpy="0 0 0" />
                        <geometry>
                                <cylinder length="${link2_length}" radius="${link_radius}"/>
                        </geometry>
                        <material name="link2"/>
                </visual>
                <visual name="joint3">
                        <origin xyz="0 0 ${link2_length}" rpy="1.5708 0 0" />
                        <geometry>
                                <cylinder length="${joint_length}" radius="${joint_radius}"/>
                        </geometry>
                        <material name="link2"/>
                </visual>
        </link>

        <!-- Elbow pitch joint -->
        <joint name="joint3" type="revolute">
                <parent link="link2" />
                <child link="link3" />
                <origin xyz="0.0 -${joint_length} ${link2_length}" rpy="0.0 0.0 0.0" />
                <axis xyz="0 1 0" />
                <limit lower="${-pi}" upper="${pi}" effort="1.0" velocity="10.0"/>
        </joint>

        <link name="link3">
                <inertial>
                        <origin xyz="0 0 ${link3_length / 2.0}" rpy="0 0 0"/>
                        <mass value="1"/>
                        <inertia ixx="1.0" ixy="0" ixz="0" iyy="1.0" iyz="0" izz="1.0" />
                </inertial>
                <visual name="joint3">
                        <origin xyz="0 0 0" rpy="1.5708 0 0" />
                        <geometry>
                                <cylinder length="${joint_length}" radius="${joint_radius}"/>
                        </geometry>
                        <material name="link3"/>
                </visual>
                <visual name="link">
                        <origin xyz="0 0 ${link3_length / 2.0}" rpy="0 0 0" />
                        <geometry>
                                <cylinder length="${link3_length}" radius="${link_radius}"/>
                        </geometry>
                        <material name="link3"/>
                </visual>
                <visual name="joint4">
                        <origin xyz="0 0 ${link3_length}" rpy="1.5708 0 0" />
                        <geometry>
                                <cylinder length="${joint_length}" radius="${joint_radius}"/>
                        </geometry>
                        <material name="link3"/>
                </visual>
        </link>

        <!-- Wrist pitch joint -->
        <joint name="joint4" type="revolute">
                <parent link="link3" />
                <child link="link4" />
                <origin xyz="0.0 ${joint_length} ${link3_length}" rpy="0.0 0.0 0.0" />
                <axis xyz="0 1 0" />
                <limit lower="${-2.0 * pi}" upper="${2.0 * pi}" effort="1.0" velocity="10.0"/>
        </joint>

        <link name="link4">
                <inertial>
                        <origin xyz="0 0 ${link4_length / 2.0}" rpy="0 0 0"/>
                        <mass value="1"/>
                        <inertia ixx="1.0" ixy="0" ixz="0" iyy="1.0" iyz="0" izz="1.0" />
                </inertial>
                <visual name="joint4">
                        <origin xyz="0 0 0" rpy="1.5708 0 0" />
                        <geometry>
                                <cylinder length="${joint_length}" radius="${joint_radius}"/>
                        </geometry>
                        <material name="link4"/>
                </visual>
                <visual name="link">
                        <origin xyz="0 0 ${link4_length / 2.0}" rpy="0 0 0" />
                        <geometry>
                                <cylinder length="${link4_length}" radius="${link_radius}"/>
                        </geometry>
                        <material name="link4"/>
                </visual>
                <visual name="joint5">
                        <origin xyz="0 0 ${link4_length}" rpy="0 1.5708 0" />
                        <geometry>
                                <cylinder length="${joint_length}" radius="${joint_radius}"/>
                        </geometry>
                        <material name="link4"/>
                </visual>
        </link>

        <!-- Wrist roll joint -->
        <joint name="joint5" type="revolute">
                <parent link="link4" />
                <child link="link5" />
                <origin xyz="0.0 0 ${link4_length}" rpy="0.0 ${pi / 2.0} 0.0" />
                <axis xyz="0 0 1" />
                <limit lower="${-2.0 * pi}" upper="${2.0 * pi}" effort="1.0" velocity="2.0"/>
        </joint>

        <link name="link5">
                <inertial>
                        <origin xyz="0 0 ${link5_length / 2.0}" rpy="0 0 0"/>
                        <mass value="0.5"/>
                        <inertia ixx="1.0" ixy="0" ixz="0" iyy="1.0" iyz="0" izz="1.0" />
                </inertial>

                <!-- Link cylinder -->
                <visual name="joint5">
                        <origin xyz="0 0 0" rpy="0 0 0" />
                        <geometry>
                                <cylinder length="${joint_length}" radius="${joint_radius}"/>
                        </geometry>
                        <material name="link5"/>
                </visual>
                <visual name="link">
                        <origin xyz="0 0 ${link5_length / 2.0}" rpy="0 0 0" />
                        <geometry>
                                <cylinder length="${link5_length}" radius="${link_radius}"/>
                        </geometry>
                        <material name="link5"/>
                </visual>

                <!-- Gripper visuals at tip of link5 (offset by link5_length in z) -->
                <visual name="gripper_base">
                        <origin xyz="0 0 ${link5_length}" rpy="0 0 0" />
                        <geometry>
                                <box size="${joint_radius * 2} ${joint_radius * 2.5} ${joint_length}"/>
                        </geometry>
                        <material name="joint_part1"/>
                </visual>
                <visual name="right_finger_1">
                        <origin xyz="${joint_radius * 2} ${joint_radius} ${link5_length}" rpy="0 0 0.3" />
                        <geometry>
                                <box size="${joint_length * 3} ${joint_radius * 0.8} ${joint_radius * 0.8}"/>
                        </geometry>
                        <material name="joint_part2"/>
                </visual>
                <visual name="right_finger_2">
                        <origin xyz="${joint_radius * 3.75} ${joint_radius * 1.5} ${link5_length}" rpy="0 0 1.2" />
                        <geometry>
                                <box size="${joint_length * 1.5} ${joint_radius * 0.8} ${joint_radius * 0.8}"/>
                        </geometry>
                        <material name="joint_part2"/>
                </visual>
                <visual name="left_finger_1">
                        <origin xyz="${joint_radius * 2} -${joint_radius} ${link5_length}" rpy="0 0 -0.3" />
                        <geometry>
                                <box size="${joint_length * 3} ${joint_radius * 0.8} ${joint_radius * 0.8}"/>
                        </geometry>
                        <material name="joint_part2"/>
                </visual>
                <visual name="left_finger_2">
                        <origin xyz="${joint_radius * 3.75} -${joint_radius * 1.5} ${link5_length}" rpy="0 0 -1.2" />
                        <geometry>
                                <box size="${joint_length * 1.5} ${joint_radius * 0.8} ${joint_radius * 0.8}"/>
                        </geometry>
                        <material name="joint_part2"/>
                </visual>
        </link>

        <!-- Attach sensor_link at tip of link5 -->
        <joint name="sensor_link_joint" type="fixed">
                <origin xyz="0 0 ${link5_length}" rpy="0 0 0"/>
                <parent link="link5"/>
                <child link="sensor_link"/>
        </joint>
        <link name="sensor_link"/>

        <!-- tool0 = grasp point between fingers (offset in x toward finger tips) -->
        <joint name="tool0_joint" type="fixed">
                <origin xyz="${joint_radius * 3.5} 0 0" rpy="0 0 0"/>
                <parent link="sensor_link"/>
                <child link="tool0"/>
        </joint>
        <link name="tool0"/>


        <!-- Additional links for integration tests -->
        <joint name="invalid_sensor_link_joint" type="fixed">
                <origin xyz="0 0 ${link5_length * 3}" rpy="0 0 0"/>
                <parent link="link5"/>
                <child link="invalid_sensor_link"/>
        </joint>
        <link name="invalid_sensor_link"/>

        <joint name="invalid_compliance_link_joint" type="fixed">
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <parent link="sensor_link"/>
                <child link="invalid_compliance_link"/>
        </joint>
        <link name="invalid_compliance_link"/>

        <gazebo reference="base_link">
        <gravity>false</gravity>
        <material>
                <ambient>0.956 0.796 0.631 1</ambient>
                <diffuse>0.956 0.796 0.631 1</diffuse>
        </material>
        </gazebo>

        <gazebo reference="link1">
        <gravity>false</gravity>
        <material>
                <ambient>0.949 0.631 0.823 1</ambient>
                <diffuse>0.949 0.631 0.823 1</diffuse>
        </material>
        </gazebo>

        <gazebo reference="link2">
        <gravity>false</gravity>
        <material>
                <ambient>0.133 0.827 0.435 1</ambient>
                <diffuse>0.133 0.827 0.435 1</diffuse>
        </material>
        </gazebo>

        <gazebo reference="link3">
        <gravity>false</gravity>
        <material>
                <ambient>0.968 0.721 0.313 1</ambient>
                <diffuse>0.968 0.721 0.313 1</diffuse>
        </material>
        </gazebo>

        <gazebo reference="link4">
        <gravity>false</gravity>
        <material>
                <ambient>0.525 0.529 0.647 1</ambient>
                <diffuse>0.525 0.529 0.647 1</diffuse>
        </material>
        </gazebo>

        <gazebo reference="link5">
        <gravity>false</gravity>
        <material>
                <ambient>0.478 0.416 0.663 1</ambient>
                <diffuse>0.478 0.416 0.663 1</diffuse>
        </material>
        </gazebo>

</robot>
